# ─────────────────────────────────────────────────────────────────────────────
# Envelock server configuration
#
#   cp .env.example .env
#
# Only the values marked REQUIRED are needed to boot locally. Everything else
# degrades gracefully — an unset provider disables the detections that depend on
# it, and the mailbox protection level (PRD E7) reflects that rather than
# silently pretending coverage exists.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
# development | staging | production
ENVELOCK_ENV=development
ENVELOCK_LOG_LEVEL=INFO
ENVELOCK_API_HOST=0.0.0.0
ENVELOCK_API_PORT=8010

# REQUIRED. Signs sessions and tokens. Generate: openssl rand -hex 32
ENVELOCK_SECRET_KEY=

# REQUIRED in production. Master key for envelope-encrypting tenant mail
# credentials (PRD §5.2). In production this must be a KMS/HSM key reference,
# never a literal. Generate for local dev: openssl rand -hex 32
ENVELOCK_CREDENTIAL_MASTER_KEY=
# production: arn:aws:kms:... or equivalent
ENVELOCK_KMS_KEY_ID=

# ── Datastores ───────────────────────────────────────────────────────────────
# REQUIRED. Tenant, config, counterparty and bank-registry state.
ENVELOCK_POSTGRES_DSN=postgresql+asyncpg://envelock:envelock@localhost:5432/envelock

# REQUIRED. Worker queue and cache (incl. the shared attachment verdict cache).
ENVELOCK_REDIS_DSN=redis://localhost:6379/0

# Mail and audit event telemetry. Grows very large — never put this in Postgres.
ENVELOCK_CLICKHOUSE_DSN=clickhouse://envelock:envelock@localhost:8123/envelock

# Event bus between channel ingest and the detection workers.
ENVELOCK_KAFKA_BOOTSTRAP=localhost:19092
ENVELOCK_KAFKA_TOPIC_EVENTS=envelock.events

# ─────────────────────────────────────────────────────────────────────────────
# CHANNEL 1 — MAIL (content)
# ─────────────────────────────────────────────────────────────────────────────

# ── Tier 1: Microsoft 365 (Graph) ────────────────────────────────────────────
ENVELOCK_MS_CLIENT_ID=
ENVELOCK_MS_CLIENT_SECRET=
ENVELOCK_MS_REDIRECT_URI=http://localhost:8010/api/v1/connect/microsoft/callback
# public HTTPS URL for Graph change notifications
ENVELOCK_MS_WEBHOOK_URL=

# ── Tier 1: Google Workspace ─────────────────────────────────────────────────
ENVELOCK_GOOGLE_CLIENT_ID=
ENVELOCK_GOOGLE_CLIENT_SECRET=
ENVELOCK_GOOGLE_REDIRECT_URI=http://localhost:8010/api/v1/connect/google/callback
# projects/<proj>/topics/<topic>
ENVELOCK_GOOGLE_PUBSUB_TOPIC=

# ── Tier 3: IMAP connection broker (PRD §5.3, §12.11D) ───────────────────────
# Protected mailboxes hold IDLE (latency is the product — we must quarantine
# before the user acts). Monitored mailboxes poll (no persistent connection, so
# the per-IP concurrency ceiling stops binding). Both paths ship from day one.
ENVELOCK_IMAP_IDLE_ENABLED=true
# 15 min — adequate for Group C
ENVELOCK_IMAP_MONITORED_POLL_SECONDS=900
# MEASURE per provider; see PRD §12.11C
ENVELOCK_IMAP_MAX_CONNECTIONS_PER_EGRESS_IP=15
# re-issue before the RFC 29-min limit
ENVELOCK_IMAP_IDLE_REFRESH_SECONDS=1500
# stagger, or a restart becomes a storm
ENVELOCK_IMAP_RECONNECT_JITTER_SECONDS=120
# comma-separated rotation pool
ENVELOCK_IMAP_EGRESS_IPS=

# ── Tier 4: forwarding ingest ────────────────────────────────────────────────
# per-tenant addresses: t-<id>@<this>
ENVELOCK_INGEST_DOMAIN=in.envelock.io
ENVELOCK_INGEST_SMTP_HOST=0.0.0.0
ENVELOCK_INGEST_SMTP_PORT=2525

# ─────────────────────────────────────────────────────────────────────────────
# CHANNEL 2 — IDENTITY (who / where / when)
# ─────────────────────────────────────────────────────────────────────────────

# Web Push for the client sensor. Free, self-hosted, no third party — this is
# rung L1 of the notification ladder (PRD §8.1).
# Generate: vapid --gen   (or py_vapid)
ENVELOCK_VAPID_PUBLIC_KEY=
ENVELOCK_VAPID_PRIVATE_KEY=
ENVELOCK_VAPID_SUBJECT=mailto:security@envelock.io

# IP intelligence (C6–C10). Free tiers first; see PRD §12.12D on rotation.
ENVELOCK_IPINFO_TOKEN=
ENVELOCK_IPQS_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# CHANNEL 3 — EXTERNAL (domain / brand) — almost entirely free
# ─────────────────────────────────────────────────────────────────────────────

# free, primary sensor (D2)
ENVELOCK_CERTSTREAM_URL=wss://certstream.calidog.io/

# ICANN CZDS — free gTLD zone file access (application required). This is what
# commercial NRD feeds resell. See PRD §12.12B.
ENVELOCK_CZDS_USERNAME=
ENVELOCK_CZDS_PASSWORD=

# free; primary. WHOIS is fallback only
ENVELOCK_RDAP_BOOTSTRAP_URL=https://rdap.org/

# Optional paid NRD feed — last resort, not a v1 dependency.
ENVELOCK_NRD_FEED_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# DETECTION — free-first cascades (PRD §12.12)
# ─────────────────────────────────────────────────────────────────────────────

# URL reputation. Google Safe Browsing Update API is free and is the primary.
ENVELOCK_SAFEBROWSING_API_KEY=
# free (abuse.ch)
ENVELOCK_URLHAUS_ENABLED=true
# WARNING: several "free" feeds prohibit commercial use — Spamhaus especially.
# Audit terms before enabling anything here in production. PRD §12.12C.

# Attachment cascade. Layers 0–1 are free and self-hosted; layer 3 is metered.
ENVELOCK_CLAMAV_HOST=localhost
ENVELOCK_CLAMAV_PORT=3310
ENVELOCK_YARA_RULES_PATH=./rules/yara
# clean-today can be flagged-tomorrow
ENVELOCK_ATTACHMENT_CACHE_TTL_CLEAN_DAYS=14
# layer 3 — off until revenue (v1.2)
ENVELOCK_DETONATION_ENABLED=false
# hash lookup (cheap) ≠ detonation
ENVELOCK_VIRUSTOTAL_API_KEY=
# opswat | triage | vt
ENVELOCK_DETONATION_PROVIDER=
# fair-use cap, PRD §12.10
ENVELOCK_DETONATION_MONTHLY_CAP_PER_MAILBOX=150

# ─────────────────────────────────────────────────────────────────────────────
# NOTIFICATIONS — ladder L0→L3 (PRD §8.1)
# ─────────────────────────────────────────────────────────────────────────────

# L2: our own SMTP. Privacy-motivated, not a cost saving. Deliverability is the
# real risk — our alerts must land at HiNet, 263 and Gmail. See PRD §8.3.
ENVELOCK_SMTP_HOST=localhost
ENVELOCK_SMTP_PORT=587
ENVELOCK_SMTP_USERNAME=
ENVELOCK_SMTP_PASSWORD=
ENVELOCK_SMTP_FROM=alerts@envelock.io
ENVELOCK_SMTP_DKIM_PRIVATE_KEY_PATH=
ENVELOCK_SMTP_DKIM_SELECTOR=envelock

# Relay fallback for Critical alerts if self-hosted reputation degrades.
# Ship this from day one — do not add it after the first incident.
ENVELOCK_SMTP_RELAY_FALLBACK_DSN=

# L3: SMS. Escalation only — never the default path. Fires when a Critical is
# unacknowledged 15 min, or 5+ notifications go unacknowledged, or a Critical
# fires for a user with no sensor installed.
ENVELOCK_SMS_ENABLED=false
# termii | africastalking | twilio
ENVELOCK_SMS_PROVIDER=
ENVELOCK_SMS_API_KEY=
ENVELOCK_SMS_SENDER_ID=Envelock
ENVELOCK_ESCALATE_CRITICAL_AFTER_SECONDS=900
ENVELOCK_ESCALATE_UNACKED_COUNT=5

# ─────────────────────────────────────────────────────────────────────────────
# BILLING (PRD §12)
# ─────────────────────────────────────────────────────────────────────────────

ENVELOCK_TRIAL_DAYS=15
# full 90 runs on conversion, PRD §12.7
ENVELOCK_TRIAL_BACKFILL_DAYS=30
ENVELOCK_BACKFILL_DAYS=90

ENVELOCK_STRIPE_SECRET_KEY=
ENVELOCK_STRIPE_WEBHOOK_SECRET=
# Nigeria/Africa: card, transfer, USSD
ENVELOCK_PAYSTACK_SECRET_KEY=
ENVELOCK_FLUTTERWAVE_SECRET_KEY=
ENVELOCK_PAYPAL_CLIENT_ID=
ENVELOCK_PAYPAL_CLIENT_SECRET=
